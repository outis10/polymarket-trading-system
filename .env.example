# ── Seguridad ──────────────────────────────────────────────────────────────
# Clave que valida todas las requests REST y WebSocket del frontend.
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Origins permitidos en CORS (comma-separated). Vacío = solo localhost (dev).
# Ejemplo producción: https://mi-dominio.com,https://www.mi-dominio.com
ALLOWED_ORIGINS=

# ── L1 Authentication (Clave privada del wallet) ────────────────────────────
POLYMARKET_PRIVATE_KEY=0x...

# Configuración del wallet
POLYMARKET_FUNDER=0x...  # Tu dirección de wallet (la que tiene fondos)
POLYMARKET_SIGNATURE_TYPE=0  # 0=MetaMask (EOA), 1=Magic/email, 2=proxy

# NOTA para MetaMask:
# - La clave privada debe empezar con 0x (agrégalo si no lo tiene)
# - La clave privada es la MISMA para todas las redes (Ethereum, Polygon, etc.)
# - Usa la cuenta que conectaste a Polymarket
# - Debes aprobar allowances antes de tradear (ver README)

# L2 Authentication (Generadas con generate_credentials.py)
POLYMARKET_API_KEY=...
POLYMARKET_SECRET=...
POLYMARKET_PASSPHRASE=...

# Network
USE_TESTNET=true
CHAIN_ID=80002  # 80002=testnet Polygon Amoy, 137=mainnet Polygon

# Trading configuration
MAX_POSITION_SIZE=100.0
MAX_TOTAL_EXPOSURE=500.0
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.15

# Strategy configuration
MIN_CONFIDENCE=0.7
ORDER_TIMEOUT=300

# LangChain/OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Logging
LOG_LEVEL=INFO
PORT=
