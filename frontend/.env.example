# Frontend environment variables (Vite)
# Copiar a .env.local y completar los valores

# Password para acceder al frontend (login screen)
# Dejar vacío para deshabilitar login (solo dev)
VITE_APP_PASSWORD=

# API Key del backend — debe coincidir con API_KEY en el .env del backend
# Dejar vacío para deshabilitar (solo dev)
VITE_API_KEY=
